{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(uv run *)",
      "Bash(make *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(mkdir *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "extraKnownMarketplaces": {
    "dev-loop": {
      "source": {
        "source": "directory",
        "path": "../dev-loop-skills"
      }
    }
  },
  "channelsEnabled": true,
  "enabledPlugins": {
    "dev-loop-skills@dev-loop": true
  }
}
