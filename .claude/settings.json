{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(uv run *)",
      "Bash(make *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(mkdir *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "agent-setup@agent-setup": true,
    "dev-loop-skills@ezagent42": true
  },
  "extraKnownMarketplaces": {
    "ezagent42": {
      "source": {
        "source": "git",
        "url": "https://github.com/ezagent42/ezagent42.git"
      }
    }
  },
  "channelsEnabled": true
}
